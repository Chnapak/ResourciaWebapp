{
  "manifest_version": 3,
  "name": "Resourcia – Smart Study Companion",
  "version": "1.0.0",
  "description": "Discover, save, and explore learning resources as you browse. A research companion for students.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://localhost:5001/*",
    "http://localhost:5000/*",
    "https://www.google.com/*",
    "https://google.com/*",
    "https://www.google.cz/*",
    "https://google.cz/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.svg",
      "32":  "icons/icon32.svg",
      "48":  "icons/icon48.svg",
      "128": "icons/icon128.svg"
    }
  },
  "icons": {
    "16":  "icons/icon16.svg",
    "32":  "icons/icon32.svg",
    "48":  "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/search*",
        "https://google.com/search*",
        "https://www.google.cz/search*",
        "https://google.cz/search*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
