name: dockercompose6367286787104895217
services:
  resourcia.api:
    build:
      context: C:\Users\matej\source\repos\ResourciaApi\ResourciaBackend\src
      dockerfile: Resourcia.Api/Dockerfile
    container_name: resourcia.api
    depends_on:
      resourcia.db:
        condition: service_started
        required: true
    environment:
      ASPNETCORE_ENVIRONMENT: Production
      ASPNETCORE_HTTP_PORTS: "5000"
    image: resourciaapi
    networks:
      default: null
    ports:
      - mode: ingress
        target: 5000
        published: "5000"
        protocol: tcp
      - mode: ingress
        target: 5001
        published: "5001"
        protocol: tcp
  resourcia.db:
    container_name: resourcia.db
    environment:
      POSTGRES_DB: ""
      POSTGRES_PASSWORD: ""
      POSTGRES_USER: ""
    image: postgres:latest
    networks:
      default: null
    ports:
      - mode: ingress
        target: 5432
        published: "5432"
        protocol: tcp
    volumes:
      - type: bind
        source: C:\Users\matej\source\repos\ResourciaApi\ResourciaBackend\src\.containers\resourcia-db
        target: /var/lib/postgresql/data
        bind: {}
networks:
  default:
    name: dockercompose6367286787104895217_default