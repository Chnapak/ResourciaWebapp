{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=__HOST__;Port=5432;Database=__DB__;Username=__USER__;Password=__PASSWORD__;SSL Mode=Disable"
  },
  "SmtpSettings": {
    "Host": "__SMTP_HOST__",
    "Port": 0,
    "Username": "__SMTP_USERNAME__",
    "Password": "__SMTP_PASSWORD__"
  },
  "EnvironmentSettings": {
    "FrontendHostUrl": "http://localhost:4200",
    "FrontendConfirmUrl": "/confirm-token",
    "FrontendResetPasswordUrl": "/reset-password",
    "SenderEmail": "info@example.com",
    "SenderName": "Resourcia",
    "CompleteProfileUrl": "/complete-profile"
  },
  "JwtSettings": {
    "SecretKey": "__JWT_SECRET__",
    "Issuer": "https://__ISSUER__",
    "Audience": "https://__AUDIENCE__",
    "AccessTokenExpirationInMinutes": 30,
    "RefreshTokenExpirationInDays": 14
  },
  "CloudflareSettings": {
    "Host": "https://challenges.cloudflare.com/turnstile/v0/",
    "SecretKey": "__CLOUDFLARE_SECRET__"
  },
  "OwnerDetailsSettings": {
    "Username": "__OWNER_USERNAME__",
    "Email": "__OWNER_EMAIL__",
    "Password": "__OWNER_PASSWORD__",
    "Handle": "__OWNER_HANDLE__"
  },
  "OAuthOptions": {
    "Google": {
      "ClientId": "__GOOGLE_CLIENT_ID__",
      "ClientSecret": "__GOOGLE_CLIENT_SECRET__"
    },
    "Facebook": {
      "AppId": "__FACEBOOK_APP_ID__",
      "AppSecret": "__FACEBOOK_APP_SECRET__"
    }
  },
  "Redis": {
    "ConnectionString": "__REDIS_CONNECTION__",
    "DefaultTtlMinutes": 10
  }
}
