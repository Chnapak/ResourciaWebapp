# Example environment variables for local/dev Docker runs.
# Copy to .env and fill in real values. Keep .env out of git.

# --- Docker compose database ---
POSTGRES_USER=resourcia
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=resourciadb
# Dev-only: allow non-SSL connections from Docker network (do not use in prod)
# POSTGRES_HOST_AUTH_METHOD=trust

# Optional Docker registry prefix (leave empty for local builds)
DOCKER_REGISTRY=

# Windows host variable used by docker-compose.override.yml
# Usually provided by the OS; only set if your environment lacks APPDATA.
# APPDATA=C:\\Users\\<you>\\AppData\\Roaming

# --- One-time owner bootstrap (set true only for first run) ---
BOOTSTRAP_OWNER=false
OwnerDetailsSettings__Email=owner@example.com
OwnerDetailsSettings__Username=owner
OwnerDetailsSettings__Handle=owner
OwnerDetailsSettings__Password=CHANGEME_STRONG

# --- Backend configuration (optional overrides) ---
# If API runs inside Docker (compose), use the service name:
ConnectionStrings__DefaultConnection=Host=resourcia.db;Port=5432;Database=resourciadb;Username=resourcia;Password=CHANGEME;SSL Mode=Disable
# If API runs on your host (outside Docker), use localhost instead:
# ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=resourciadb;Username=resourcia;Password=CHANGEME;SSL Mode=Disable

# --- Frontend URLs / email branding ---
EnvironmentSettings__FrontendHostUrl=http://localhost:4200
EnvironmentSettings__FrontendConfirmUrl=/confirm-token
EnvironmentSettings__FrontendResetPasswordUrl=/reset-password
EnvironmentSettings__SenderEmail=info@example.com
EnvironmentSettings__SenderName=Resourcia
EnvironmentSettings__CompleteProfileUrl=/complete-profile

JwtSettings__SecretKey=CHANGEME_JWT_SECRET
JwtSettings__Issuer=https://localhost:5001
JwtSettings__Audience=https://localhost:4200

SmtpSettings__Host=smtp.example.com
SmtpSettings__Port=587
SmtpSettings__Username=CHANGEME
SmtpSettings__Password=CHANGEME

CloudflareSettings__SecretKey=CHANGEME

OAuthOptions__Google__ClientId=CHANGEME
OAuthOptions__Google__ClientSecret=CHANGEME
OAuthOptions__Facebook__AppId=CHANGEME
OAuthOptions__Facebook__AppSecret=CHANGEME

Redis__ConnectionString=resourcia.redis:6379
Redis__DefaultTtlMinutes=10
